{
	"$schema": "node_modules/wrangler/config-schema.json",

	"name": "navplot2-scheduler",
	"main": "src/index.js",
	"compatibility_date": "2026-06-03",

	"triggers": {
		"crons": [
			"49 * * * *"
		]
	},

	"queues": {
		"consumers": [
			{
			  "queue": "navplot-queue"
			}
		]
	}

  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
